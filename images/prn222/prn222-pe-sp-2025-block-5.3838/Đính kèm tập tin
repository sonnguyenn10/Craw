document.addEventListener("DOMContentLoaded", function () {
	const triggers = document.querySelectorAll(".ah-gp-trigger");

	triggers.forEach(function (trigger) {
		trigger.addEventListener("mouseover", function () {
			const profile = trigger.querySelector(".ah-gp-profile");
			if (profile) {
				profile.style.transition = "opacity 0.2s";
				profile.style.display = "block";
				requestAnimationFrame(() => {
					profile.style.opacity = "1";
				});
			}
		});

		trigger.addEventListener("mouseout", function () {
			const profile = trigger.querySelector(".ah-gp-profile");
			if (profile) {
				profile.style.transition = "opacity 0.2s";
				profile.style.opacity = "0";
				// Sau khi hiệu ứng mờ hoàn tất, ẩn đi
				setTimeout(() => {
					if (profile.style.opacity === "0") {
						profile.style.display = "none";
					}
				}, 200); // Thời gian trùng với transition
			}
		});
	});
});

})
</script>

